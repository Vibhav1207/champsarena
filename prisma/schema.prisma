datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum TournamentType {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  ROUND_ROBIN
  SWISS
}

enum TournamentStatus {
  DRAFT
  UPCOMING
  REGISTRATION_OPEN
  ONGOING
  COMPLETED
  CANCELLED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TicketStatus {
  OPEN
  ASSIGNED
  CLOSED
}

model User {
  id                  String          @id @default(cuid())
  name                String?
  email               String?         @unique
  emailVerified       DateTime?
  image               String?
  password            String?         // Hashed password for credentials auth
  role                Role            @default(USER)
  elo                 Int             @default(1000)
  wins                Int             @default(0)
  losses              Int             @default(0)
  trainerId           String          @unique @default(uuid())
  homeRegion          String          @default("Kanto")
  favPokemon          String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  username            String?         @unique
  bio                 String?         @db.Text
  country             String?
  discordUsername     String?
  socialLinks         String?         @db.Text // Serialized JSON
  failedLoginAttempts Int             @default(0)
  lockoutUntil        DateTime?

  squadId             String?
  squad               Squad?          @relation("SquadMembers", fields: [squadId], references: [id])
  captainOf           Squad[]         @relation("SquadCaptain")
  coCaptainOf         Squad[]         @relation("SquadCoCaptain")
  squadInvitations    SquadInvitation[]

  accounts      Account[]
  sessions      Session[]
  registrations Registration[]
  teams         Team[]
  notifications Notification[]
  auditLogs     AuditLog[]
  tickets       SupportTicket[]
  replies       TicketReply[]
  assignedTickets SupportTicket[] @relation("AssignedTickets")

  // ELO and stats relations
  wonMatches    Match[]         @relation("MatchWinner")
  matchesAsP1   Match[]         @relation("MatchP1")
  matchesAsP2   Match[]         @relation("MatchP2")
  wonTournaments Tournament[]   @relation("TournamentWinner")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tournament {
  id                   String           @id @default(cuid())
  title                String
  description          String           @db.Text
  banner               String?          // URL to banner image
  rules                String           @db.Text
  entryFee             Float            @default(0.0)
  prizePool            Float            @default(0.0)
  currency             String           @default("USD")
  prizeDistribution    String           @default("TOP_8")
  maxPlayers           Int              @default(64)
  registrationDeadline DateTime
  startDate            DateTime
  endDate              DateTime
  type                 TournamentType   @default(SINGLE_ELIMINATION)
  status               TournamentStatus @default(DRAFT)
  visibility           Boolean          @default(true)
  badgeName            String?
  badgeIcon            String?
  game                 String           @default("POKEMON_VGC")
  winnerId             String?
  winner               User?            @relation("TournamentWinner", fields: [winnerId], references: [id])
  winnerSquadId        String?
  winnerSquad          Squad?           @relation("TournamentSquadWinner", fields: [winnerSquadId], references: [id])
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  registrations        Registration[]
  squadRegistrations   SquadRegistration[]
  matches              Match[]
  brackets             Bracket[]
}

model Registration {
  id           String             @id @default(cuid())
  userId       String
  tournamentId String
  status       RegistrationStatus @default(PENDING)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@unique([userId, tournamentId])
}

model Match {
  id                    String     @id @default(cuid())
  tournamentId          String
  round                 Int
  p1Id                  String?
  p2Id                  String?
  p1Score               Int        @default(0)
  p2Score               Int        @default(0)
  winnerId              String?
  status                String     @default("PENDING") // PENDING, ONGOING, COMPLETED, BYE, REPORTED, DISPUTED
  scheduledAt           DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  s1Id                  String?
  s2Id                  String?
  winnerSquadId         String?
  reportedById          String?
  reportedP1Score       Int?
  reportedP2Score       Int?
  reportedS1Score       Int?
  reportedS2Score       Int?
  reportedWinnerId      String?
  reportedWinnerSquadId String?

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  p1           User?      @relation("MatchP1", fields: [p1Id], references: [id])
  p2           User?      @relation("MatchP2", fields: [p2Id], references: [id])
  winner       User?      @relation("MatchWinner", fields: [winnerId], references: [id])
  s1           Squad?     @relation("MatchS1", fields: [s1Id], references: [id])
  s2           Squad?     @relation("MatchS2", fields: [s2Id], references: [id])
  winnerSquad  Squad?     @relation("MatchSquadWinner", fields: [winnerSquadId], references: [id])
  attachments  MatchAttachment[]
  dispute      MatchDispute?

  @@index([tournamentId])
  @@index([p1Id])
  @@index([p2Id])
  @@index([s1Id])
  @@index([s2Id])
}

model Bracket {
  id            String     @id @default(cuid())
  tournamentId  String
  structureJson String     @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  registrationId    String
  amount            Float
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  provider          String        // STRIPE or RAZORPAY
  providerPaymentId String?       @unique // Stripe Payment Intent ID or Razorpay Payment ID
  providerOrderId   String?       @unique // Stripe Session ID or Razorpay Order ID
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  registration      Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model Announcement {
  id                  String    @id @default(cuid())
  title               String
  content             String    @db.Text
  pinned              Boolean   @default(false)
  scheduledPublishAt  DateTime?
  published           Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Team {
  id          String   @id @default(cuid())
  userId      String
  name        String
  pokemonJson String   @db.Text // JSON representation of 6 Pokémon
  active      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  type      String   // INFO, MATCH, REGISTRATION, PAYMENT
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  details   String   @db.Text
  prevValue String?  @db.Text
  newValue  String?  @db.Text
  ipAddress String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
}

model SupportTicket {
  id         String       @id @default(cuid())
  userId     String
  subject    String
  message    String       @db.Text
  status     TicketStatus @default(OPEN)
  assignedId String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo User?        @relation("AssignedTickets", fields: [assignedId], references: [id])
  replies    TicketReply[]
}

model TicketReply {
  id       String   @id @default(cuid())
  ticketId String
  userId   String
  message  String   @db.Text
  createdAt DateTime @default(now())

  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum DisputeStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model MatchAttachment {
  id         String   @id @default(cuid())
  matchId    String
  url        String
  uploadedBy String
  createdAt  DateTime @default(now())

  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}

model MatchDispute {
  id           String        @id @default(cuid())
  matchId      String        @unique
  raisedById   String
  reason       String        @db.Text
  status       DisputeStatus @default(OPEN)
  resolvedById String?
  resolution   String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  match        Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Squad {
  id          String   @id @default(cuid())
  name        String   @unique
  logo        String?  // URL to logo
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     User[]   @relation("SquadMembers")
  captainId   String
  captain     User     @relation("SquadCaptain", fields: [captainId], references: [id])
  coCaptainId String?
  coCaptain   User?    @relation("SquadCoCaptain", fields: [coCaptainId], references: [id])

  invitations SquadInvitation[]
  registrations SquadRegistration[]
  matchesAsS1   Match[]  @relation("MatchS1")
  matchesAsS2   Match[]  @relation("MatchS2")
  wonMatches    Match[]  @relation("MatchSquadWinner")
  wonTournaments Tournament[] @relation("TournamentSquadWinner")
}

model SquadInvitation {
  id        String   @id @default(cuid())
  squadId   String
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  createdAt DateTime @default(now())

  @@unique([squadId, userId])
}

model SquadRegistration {
  id           String             @id @default(cuid())
  squadId      String
  squad        Squad              @relation(fields: [squadId], references: [id], onDelete: Cascade)
  tournamentId String
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  status       RegistrationStatus @default(PENDING)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([squadId, tournamentId])
}
